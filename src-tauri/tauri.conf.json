{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "gh-client",
  "version": "0.1.0",
  "identifier": "com.ymuichiro.ghclient",
  "build": {
    "beforeDevCommand": "npm --prefix ../ui run dev -- --host 127.0.0.1 --port 5173",
    "beforeBuildCommand": "npm --prefix ../ui run build",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../ui/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "gh-client",
        "width": 1440,
        "height": 940,
        "resizable": true,
        "fullscreen": false,
        "visible": false
      },
      {
        "label": "splashscreen",
        "title": "gh-client",
        "url": "/splashscreen.html",
        "width": 520,
        "height": 320,
        "resizable": false,
        "decorations": false,
        "alwaysOnTop": true,
        "visible": true,
        "center": true,
        "focus": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
